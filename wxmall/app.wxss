page {
  background-color: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: #1677ff;
}

.text-gray {
  color: #999;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 36rpx;
}

.text-xl {
  font-size: 40rpx;
}

.font-bold {
  font-weight: bold;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }
.p-20 { padding: 20rpx; }

.btn-primary {
  background: linear-gradient(135deg, #1677ff, #0958d9);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  border: none;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
  border-radius: 44rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  text-align: center;
}

.price {
  color: #1677ff;
  font-weight: bold;
}

.price::before {
  content: '\00a5';
  font-size: 0.7em;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1677ff;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-blue {
  background: #e6f4ff;
  color: #1677ff;
  border: 1rpx solid #bae0ff;
}

.tag-green {
  background: #f0fff0;
  color: #52c41a;
  border: 1rpx solid #ccffcc;
}

.tag-orange {
  background: #fff8f0;
  color: #fa8c16;
  border: 1rpx solid #ffe0b2;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #1677ff;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
  line-height: 1.4;
}