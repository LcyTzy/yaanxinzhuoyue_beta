.addr-list {
  padding: 16rpx 20rpx;
}

.addr-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.addr-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.addr-contact {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.addr-phone {
  font-size: 26rpx;
  color: #666;
}

.addr-detail {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.addr-icon-loc {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.addr-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.addr-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.addr-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.action-icon {
  font-size: 24rpx;
}

.bottom-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
}

.bottom-btn .btn-primary {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 36rpx;
  font-weight: 300;
  margin-right: 8rpx;
}