.page {
  display: flex;
  height: calc(100vh - 100rpx);
}

.left-nav {
  width: 180rpx;
  background: #f8f8f8;
  height: 100%;
}

.nav-item {
  padding: 32rpx 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  position: relative;
  transition: all 0.2s;
}

.nav-item.active {
  background: #fff;
  color: #1677ff;
  font-weight: bold;
  font-size: 28rpx;
}

.nav-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: #1677ff;
  border-radius: 3rpx;
}

.right-content {
  flex: 1;
  height: 100%;
  background: #fff;
  padding: 12rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
}

.product-card {
  width: calc(50% - 10rpx);
  margin: 0 5rpx 16rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.product-img {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.product-info {
  padding: 14rpx;
}

.product-name {
  font-size: 24rpx;
  color: #333;
  line-height: 1.4;
  height: 66rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.sales {
  font-size: 20rpx;
  color: #bbb;
}

.load-end {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  padding: 30rpx 0;
}