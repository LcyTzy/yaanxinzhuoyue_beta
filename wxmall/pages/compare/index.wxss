.page { min-height: 100vh; background: #f0f2f5; }
.header-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 30rpx; background: #fff; }
.header-title { font-size: 28rpx; color: #333; font-weight: 500; }
.clear-btn { font-size: 26rpx; color: #ff4d4f; }
.table-scroll { width: 100%; }
.table { display: flex; flex-direction: column; min-width: 100%; }
.table-row { display: flex; border-bottom: 1rpx solid #f0f0f0; }
.table-row.header-row { background: #fff; position: sticky; top: 0; z-index: 1; }
.row-label { width: 140rpx; flex-shrink: 0; padding: 20rpx 16rpx; font-size: 24rpx; color: #999; background: #fafafa; display: flex; align-items: center; }
.row-cell { flex: 1; padding: 16rpx; font-size: 24rpx; color: #333; display: flex; flex-direction: column; align-items: center; text-align: center; min-width: 200rpx; }
.cell-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f5f5f5; margin-bottom: 8rpx; }
.cell-name { font-size: 24rpx; color: #333; margin-bottom: 4rpx; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.cell-price { font-size: 28rpx; color: #ff4d4f; font-weight: bold; margin-bottom: 8rpx; }
.cell-remove { font-size: 22rpx; color: #ff4d4f; padding: 4rpx 16rpx; border: 1rpx solid #ff4d4f; border-radius: 16rpx; }
.empty { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 20rpx; }
.empty-tip { font-size: 24rpx; color: #bbb; margin-top: 10rpx; }
.go-btn { margin-top: 30rpx; padding: 16rpx 60rpx; background: #1677ff; color: #fff; border-radius: 40rpx; font-size: 28rpx; }