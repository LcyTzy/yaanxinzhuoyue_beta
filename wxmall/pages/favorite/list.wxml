<view class="page">
  <view class="list" wx:if="{{favorites.length > 0}}">
    <view class="item" wx:for="{{favorites}}" wx:key="id" bindtap="goDetail" data-id="{{item.productId}}">
      <image class="item-img" src="{{item.productImage || '/images/placeholder.png'}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
      <view class="item-info">
        <text class="item-name">{{item.productName}}</text>
        <text class="item-sub" wx:if="{{item.productSubName}}">{{item.productSubName}}</text>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price}}</text>
          <text class="remove-btn" catchtap="removeFavorite" data-id="{{item.productId}}">取消收藏</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && favorites.length === 0}}">
    <text class="empty-icon">💔</text>
    <text class="empty-text">还没有收藏的商品</text>
    <navigator url="/pages/product/list" class="go-btn">去逛逛</navigator>
  </view>

  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="no-more" wx:if="{{!hasMore && favorites.length > 0}}">
    <text>— 没有更多了 —</text>
  </view>
</view>