<view class="page">
  <view class="header-bar">
    <text class="header-title">保险/年检</text>
    <text class="apply-btn" bindtap="showForm">立即申请</text>
  </view>

  <view class="list" wx:if="{{services.length > 0}}">
    <view class="item" wx:for="{{services}}" wx:key="id">
      <view class="item-row"><text class="item-label">服务类型</text><text class="item-value">{{item.serviceType === 'INSURANCE' ? '车险服务' : item.serviceType === 'INSPECTION' ? '年检服务' : item.serviceType}}</text></view>
      <view class="item-row"><text class="item-label">车辆信息</text><text class="item-value">{{item.vehicleInfo}}</text></view>
      <view class="item-row"><text class="item-label">联系人</text><text class="item-value">{{item.contactName}}</text></view>
      <view class="item-row"><text class="item-label">状态</text><text class="item-value status">{{item.status === 0 ? '待处理' : item.status === 1 ? '处理中' : item.status === 2 ? '已完成' : '已取消'}}</text></view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && services.length === 0}}">
    <text class="empty-icon">🛡️</text>
    <text class="empty-text">暂无保险/年检记录</text>
  </view>

  <view class="form-mask" wx:if="{{showForm}}" bindtap="hideForm">
    <view class="form-panel" catchtap="">
      <text class="form-title">申请保险/年检</text>
      <view class="form-item">
        <text class="label">服务类型 *</text>
        <picker mode="selector" range="{{['车险服务', '年检服务']}}" bindchange="onTypeChange">
          <view class="picker">{{form.serviceType === 'INSURANCE' ? '车险服务' : '年检服务'}}</view>
        </picker>
      </view>
      <view class="form-item"><text class="label">车辆信息 *</text><input class="input" value="{{form.vehicleInfo}}" data-field="vehicleInfo" bindinput="onInput" placeholder="品牌型号/车牌号" /></view>
      <view class="form-item"><text class="label">联系人 *</text><input class="input" value="{{form.contactName}}" data-field="contactName" bindinput="onInput" placeholder="请输入联系人" /></view>
      <view class="form-item"><text class="label">联系电话 *</text><input class="input" value="{{form.contactPhone}}" data-field="contactPhone" bindinput="onInput" placeholder="请输入联系电话" type="number" /></view>
      <view class="form-item"><text class="label">备注</text><input class="input" value="{{form.remark}}" data-field="remark" bindinput="onInput" placeholder="备注信息" /></view>
      <view class="form-btns">
        <button class="cancel-btn" bindtap="hideForm">取消</button>
        <button class="submit-btn" bindtap="submit">提交申请</button>
      </view>
    </view>
  </view>
</view>