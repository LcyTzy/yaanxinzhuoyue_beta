.page {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.search-bar {
  display: flex;
  margin: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 70rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.search-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #1677ff;
  color: #fff;
  font-size: 26rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  padding: 0;
  text-align: center;
}

.list {
  padding: 0 20rpx;
}

.item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 16rpx;
}

.item-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.item-code {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.item-stock {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}

.stock-label {
  font-size: 22rpx;
  color: #999;
}

.stock-num {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.stock-num.warn {
  color: #fa8c16;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 12rpx;
}

.action-btn {
  width: 100rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
  padding: 0;
  text-align: center;
}

.action-btn.in {
  background: #e6f4ff;
  color: #1677ff;
}

.action-btn.out {
  background: #fff0f0;
  color: #ff4d4f;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.3;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}