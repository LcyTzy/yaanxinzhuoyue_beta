<view class="page">
  <view class="header-bar">
    <text class="header-title">我的发票</text>
    <text class="apply-btn" bindtap="showApplyForm">申请发票</text>
  </view>

  <view class="list" wx:if="{{invoices.length > 0}}">
    <view class="item" wx:for="{{invoices}}" wx:key="id">
      <view class="item-row">
        <text class="item-label">发票抬头</text>
        <text class="item-value">{{item.title}}</text>
      </view>
      <view class="item-row">
        <text class="item-label">类型</text>
        <text class="item-value">{{item.type === 1 ? '电子发票' : '纸质发票'}}</text>
      </view>
      <view class="item-row">
        <text class="item-label">金额</text>
        <text class="item-value price">¥{{item.amount}}</text>
      </view>
      <view class="item-row">
        <text class="item-label">状态</text>
        <text class="item-value status">{{item.status === 0 ? '待处理' : item.status === 1 ? '已开票' : item.status === 2 ? '已邮寄' : '已完成'}}</text>
      </view>
      <view class="item-row" wx:if="{{item.createTime}}">
        <text class="item-label">申请时间</text>
        <text class="item-value">{{item.createTime}}</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && invoices.length === 0}}">
    <text class="empty-icon">🧾</text>
    <text class="empty-text">暂无发票记录</text>
  </view>

  <view class="form-mask" wx:if="{{showForm}}" bindtap="hideForm">
    <view class="form-panel" catchtap="">
      <text class="form-title">申请发票</text>
      <view class="form-item">
        <text class="label">订单号 *</text>
        <input class="input" value="{{form.orderId}}" data-field="orderId" bindinput="onInput" placeholder="请输入订单号" />
      </view>
      <view class="form-item">
        <text class="label">发票抬头 *</text>
        <input class="input" value="{{form.title}}" data-field="title" bindinput="onInput" placeholder="请输入发票抬头" />
      </view>
      <view class="form-item">
        <text class="label">税号</text>
        <input class="input" value="{{form.taxNo}}" data-field="taxNo" bindinput="onInput" placeholder="请输入税号（选填）" />
      </view>
      <view class="form-item">
        <text class="label">邮箱</text>
        <input class="input" value="{{form.email}}" data-field="email" bindinput="onInput" placeholder="接收电子发票的邮箱" />
      </view>
      <view class="form-item">
        <text class="label">类型</text>
        <radio-group bindchange="onTypeChange">
          <label class="radio-item"><radio value="1" checked="{{form.type === 1}}" color="#1677ff" /> 电子发票</label>
          <label class="radio-item"><radio value="2" checked="{{form.type === 2}}" color="#1677ff" /> 纸质发票</label>
        </radio-group>
      </view>
      <view class="form-btns">
        <button class="cancel-btn" bindtap="hideForm">取消</button>
        <button class="submit-btn" bindtap="submit">提交申请</button>
      </view>
    </view>
  </view>
</view>