<view class="page">
  <view class="header">
    <text class="title">重置密码</text>
    <text class="subtitle">请输入手机号获取验证码</text>
  </view>

  <view class="card">
    <view class="input-row">
      <text class="input-label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">验证码</text>
      <input class="input code-input" type="number" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" maxlength="6" />
      <button class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode" disabled="{{countdown > 0 || sending}}">
        {{countdown > 0 ? countdown + 's' : (sending ? '发送中' : '获取验证码')}}
      </button>
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">新密码</text>
      <input class="input" type="password" placeholder="请设置新密码（至少6位）" value="{{newPassword}}" bindinput="onNewPasswordInput" />
    </view>

    <button class="btn" bindtap="resetPassword" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '重置中...' : '重置密码'}}
    </button>
  </view>

  <view class="footer">
    <text class="footer-link" bindtap="goLogin">返回登录</text>
  </view>
</view>