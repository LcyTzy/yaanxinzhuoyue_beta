<view class="page">
  <view class="header">
    <view class="logo-wrap">
      <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    </view>
    <text class="title">新卓阅汽配</text>
    <text class="subtitle">专业汽车配件商城</text>
  </view>

  <view class="card">
    <view class="login-tabs">
      <view class="tab {{loginType === 'user' ? 'active' : ''}}" bindtap="switchTab" data-type="user">用户登录</view>
      <view class="tab {{loginType === 'admin' ? 'active' : ''}}" bindtap="switchTab" data-type="admin">管理员登录</view>
    </view>

    <view class="input-row">
      <text class="input-label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">密码</text>
      <input class="input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="forgot-row" wx:if="{{loginType === 'user'}}">
      <text class="forgot-link" bindtap="goForgot">忘记密码？</text>
    </view>

    <button class="btn" bindtap="doLogin" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '登录中...' : (loginType === 'admin' ? '管理员登录' : '登 录')}}
    </button>
  </view>

  <view class="footer" wx:if="{{loginType === 'user'}}">
    <text class="footer-text">还没有账号？</text>
    <text class="footer-link" bindtap="goRegister">立即注册</text>
  </view>
</view>