.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #0f3460 40%, #f0f2f5 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  padding-bottom: 60rpx;
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
  margin-bottom: 28rpx;
}

.logo {
  width: 90rpx;
  height: 90rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 10rpx;
}

.card {
  width: 650rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}

.login-tabs {
  display: flex;
  margin-bottom: 36rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 6rpx;
}

.login-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.login-tabs .tab.active {
  background: #1677ff;
  color: #fff;
  font-weight: 500;
}

.input-row {
  display: flex;
  align-items: center;
  height: 90rpx;
}

.input-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 90rpx;
}

.divider {
  height: 1rpx;
  background: #eee;
}

.forgot-row {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 0 30rpx;
}

.forgot-link {
  font-size: 26rpx;
  color: #1677ff;
}

.btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #1677ff, #0958d9);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: none;
  letter-spacing: 8rpx;
}

.btn[disabled] {
  opacity: 0.6;
}

.footer {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  font-size: 26rpx;
}

.footer-text {
  color: #999;
}

.footer-link {
  color: #1677ff;
  margin-left: 8rpx;
}