<view class="page">
  <view class="header">
    <text class="title">创建账号</text>
    <text class="subtitle">注册后即可选购汽配零件</text>
  </view>

  <view class="card">
    <view class="input-row">
      <text class="input-label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">密码</text>
      <input class="input" type="password" placeholder="请设置密码（至少6位）" value="{{password}}" bindinput="onPasswordInput" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">确认密码</text>
      <input class="input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>
    <view class="divider"></view>
    <view class="input-row">
      <text class="input-label">验证码</text>
      <input class="input code-input" type="text" placeholder="请输入验证码" value="{{captcha}}" bindinput="onCaptchaInput" maxlength="4" />
      <image class="captcha-img" src="{{captchaImage}}" bindtap="refreshCaptcha" mode="aspectFit" wx:if="{{captchaImage}}" />
    </view>

    <button class="btn" bindtap="register" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '注册中...' : '注 册'}}
    </button>
  </view>

  <view class="footer">
    <text class="footer-text">已有账号？</text>
    <text class="footer-link" bindtap="goLogin">立即登录</text>
  </view>
</view>