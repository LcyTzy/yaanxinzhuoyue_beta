.address-card {
  margin: 20rpx;
}

.addr-content {
  width: 100%;
}

.addr-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.addr-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #999;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.addr-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1677ff;
}

.order-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 26rpx;
  color: #333;
}

.remark-input {
  font-size: 26rpx;
  padding: 16rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
  z-index: 100;
}

.submit-info {
  flex: 1;
  padding-right: 24rpx;
}

.submit-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.submit-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  padding: 0;
}