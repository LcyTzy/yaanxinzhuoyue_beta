<view class="page">
  <view class="card">
    <view class="info-row">
      <text class="info-label">订单状态</text>
      <text class="info-value status">{{order.statusText}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.createTime}}</text>
    </view>
  </view>

  <view class="card">
    <text class="section-title">收货信息</text>
    <view class="flex-between">
      <text class="font-bold">{{order.receiverName}}</text>
      <text>{{order.receiverPhone}}</text>
    </view>
    <text class="address-text">{{order.receiverAddress}}</text>
  </view>

  <view class="card">
    <text class="section-title">商品信息</text>
    <view class="order-item" wx:for="{{items}}" wx:key="id">
      <image class="item-img" src="{{item.productImage || '/images/placeholder.png'}}" mode="aspectFill" binderror="onItemImageError" data-index="{{index}}" />
      <view class="item-info">
        <text class="item-name ellipsis-2">{{item.productName}}</text>
        <view class="flex-between mt-10">
          <text class="price">{{item.price}}</text>
          <text class="text-gray">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="info-row">
      <text class="info-label">商品合计</text>
      <text class="price">{{order.totalAmount}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">运费</text>
      <text>免运费</text>
    </view>
    <view class="info-row total">
      <text class="info-label">实付金额</text>
      <text class="price text-lg">{{order.payAmount || order.totalAmount}}</text>
    </view>
  </view>

  <view class="bottom-actions safe-bottom" wx:if="{{order.status === 0}}">
    <button class="btn-primary" bindtap="payOrder">去支付</button>
  </view>
  <view class="bottom-actions safe-bottom" wx:if="{{order.status === 2}}">
    <button class="btn-primary" bindtap="confirmReceive">确认收货</button>
  </view>
</view>