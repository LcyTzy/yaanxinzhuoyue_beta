.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.status {
  color: #1677ff;
  font-weight: bold;
}

.info-row.total {
  border-top: 1rpx solid #f5f5f5;
  margin-top: 8rpx;
  padding-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1677ff;
}

.address-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.order-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 26rpx;
  color: #333;
}

.bottom-actions {
  padding: 24rpx;
}

.bottom-actions .btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
}