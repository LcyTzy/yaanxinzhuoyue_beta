<view class="page">
  <view class="tabs">
    <view class="tab-item {{activeTab === index ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="*this"
          bindtap="switchTab" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <view wx:if="{{orders.length === 0}}" class="empty-state">
    <text class="empty-icon">📦</text>
    <text>暂无订单</text>
  </view>

  <view wx:else class="order-list">
    <view class="order-card card" wx:for="{{orders}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="flex-between mb-20">
        <text class="text-sm text-gray">订单号: {{item.orderNo}}</text>
        <text class="status-text">{{item.statusText}}</text>
      </view>

      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="oi">
          <image class="oi-img" src="{{oi.productImage || '/images/placeholder.png'}}" mode="aspectFill" binderror="onItemImageError" data-index="{{index}}" />
          <view class="oi-info">
            <text class="oi-name ellipsis-2">{{oi.productName}}</text>
            <view class="flex-between mt-10">
              <text class="price">{{oi.price}}</text>
              <text class="text-gray">x{{oi.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="flex-between mt-20">
        <text class="text-sm">共{{item.items.length}}件</text>
        <text>合计: <text class="price">{{item.payAmount || item.totalAmount}}</text></text>
      </view>

      <view class="order-actions mt-20" wx:if="{{item.status === 0}}">
        <button class="btn-primary action-btn" catchtap="payOrder" data-order="{{item}}">去支付</button>
      </view>
      <view class="order-actions mt-20" wx:if="{{item.status === 2}}">
        <button class="btn-primary action-btn" catchtap="confirmReceive" data-id="{{item.id}}">确认收货</button>
      </view>
    </view>
  </view>
</view>