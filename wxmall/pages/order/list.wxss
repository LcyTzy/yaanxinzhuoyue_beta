.tabs {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 26rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  color: #1677ff;
  font-weight: bold;
  border-bottom-color: #1677ff;
}

.order-list {
  padding: 16rpx;
}

.order-card {
  margin: 0 0 16rpx;
}

.status-text {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: 500;
}

.order-items {
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
  padding: 16rpx 0;
}

.order-item {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
}

.oi-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.oi-info {
  flex: 1;
}

.oi-name {
  font-size: 24rpx;
  color: #333;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0;
  border-radius: 30rpx;
}