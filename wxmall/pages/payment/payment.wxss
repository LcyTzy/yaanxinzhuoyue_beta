.pay-header {
  background: linear-gradient(160deg, #1a1a2e 0%, #0f3460 100%);
  padding: 50rpx 40rpx 60rpx;
  text-align: center;
  color: #fff;
}

.pay-amount-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 12rpx;
}

.pay-amount {
  font-size: 72rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.pay-order-no {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 16rpx;
}

.pay-methods {
  margin-bottom: 30rpx;
}

.pay-method {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #1677ff;
  border-radius: 14rpx;
  background: #f0f5ff;
}

.pm-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.pm-green {
  background: #e8f5e9;
}

.pm-icon {
  font-size: 36rpx;
}

.pm-info {
  flex: 1;
}

.pm-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.pm-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.pm-check {
  width: 40rpx;
  height: 40rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.pay-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

.qr-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.qr-img {
  width: 400rpx;
  height: 400rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  background: #fff;
}

.qr-loading {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  color: #999;
  font-size: 26rpx;
}

.qr-tip {
  font-size: 26rpx;
  color: #666;
  margin-top: 24rpx;
}

.pay-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.pay-actions .btn-outline {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}

.pay-actions .btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.success-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: center;
}

.success-wrap .btn-primary {
  width: 360rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.safe-area {
  height: 40rpx;
}