.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.points-header {
  background: linear-gradient(160deg, #1a1a2e 0%, #0f3460 100%);
  padding: 40rpx 32rpx 50rpx;
  color: #fff;
  text-align: center;
}

.points-balance {
  font-size: 72rpx;
  font-weight: bold;
}

.points-label {
  font-size: 26rpx;
  opacity: 0.75;
  margin-top: 8rpx;
  display: block;
}

.sign-row {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}

.sign-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #ff8c00, #ff6b00);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 36rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.sign-btn.signed {
  background: rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.7);
}

.sign-tip {
  font-size: 22rpx;
  opacity: 0.6;
  margin-top: 12rpx;
}

.section-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1677ff;
}

.exchange-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.exchange-item {
  width: calc(50% - 8rpx);
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.exchange-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #eee;
  margin: 0 auto 12rpx;
}

.exchange-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.exchange-points {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: bold;
  margin-top: 8rpx;
}

.exchange-btn {
  width: 140rpx;
  height: 52rpx;
  line-height: 52rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  font-size: 24rpx;
  border-radius: 26rpx;
  margin: 12rpx auto 0;
  border: none;
  padding: 0;
}

.exchange-btn.disabled {
  background: #ccc;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
}

.record-desc {
  font-size: 28rpx;
  color: #333;
}

.record-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.record-points {
  font-size: 30rpx;
  font-weight: bold;
}

.record-points.positive {
  color: #ff6b00;
}

.record-points.negative {
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}