.page {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 40rpx;
}

.points-card {
  margin: 20rpx;
}

.points-bg {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
}

.points-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.points-value {
  font-size: 64rpx;
  font-weight: bold;
  display: block;
  margin: 10rpx 0 20rpx;
}

.points-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sign-btn {
  padding: 12rpx 32rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
}

.sign-btn.signed {
  opacity: 0.5;
}

.record-link {
  font-size: 26rpx;
  opacity: 0.8;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx;
}

.product-item {
  width: calc(50% - 20rpx);
  margin: 0 10rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.product-img {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  padding: 12rpx 16rpx 0;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 16rpx 16rpx;
}

.product-points {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.exchange-btn {
  font-size: 24rpx;
  color: #fff;
  background: #1677ff;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.empty {
  text-align: center;
  padding: 60rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}