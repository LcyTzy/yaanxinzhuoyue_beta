<scroll-view class="page" scroll-y>
  <image class="main-image" src="{{product.image || '/images/placeholder.png'}}" mode="aspectFill" bindtap="previewImage" binderror="onImageError" />

  <view class="card">
    <view class="price-row">
      <text class="price text-xl">{{product.price}}</text>
      <text class="stock">库存: {{product.stock || 0}}</text>
    </view>
    <text class="product-title">{{product.name}}</text>
    <text class="meta">已售 {{product.sales || 0}} | {{product.brand || ''}}</text>
  </view>

  <view class="card" wx:if="{{applicableVehicles.length > 0}}">
    <text class="section-title">适用车型</text>
    <view class="vehicle-list">
      <view class="vehicle-item" wx:for="{{applicableVehicles}}" wx:key="id">
        <text class="v-name">{{item.name}} {{item.year}} {{item.displacement}}</text>
        <text class="v-pos">{{item.position}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <text class="section-title">商品详情</text>
    <view class="detail-content">
      <text>{{product.description || '暂无详细描述'}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{reviews.length > 0}}">
    <text class="section-title">用户评价 ({{reviews.length}})</text>
    <view class="review-item" wx:for="{{reviews}}" wx:key="id">
      <view class="flex-between">
        <text class="font-bold">{{item.userName || '匿名用户'}}</text>
        <text class="text-sm text-gray">{{item.createTime}}</text>
      </view>
      <view class="stars mt-10">
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="{{index < item.rating ? 'star-active' : 'star'}}">★</text>
      </view>
      <text class="review-text">{{item.content}}</text>
    </view>
  </view>

  <view style="height: 130rpx;"></view>
</scroll-view>

<view class="bottom-bar safe-bottom">
  <view class="quantity-control">
    <view class="qty-btn" bindtap="subQuantity">−</view>
    <text class="qty-num">{{quantity}}</text>
    <view class="qty-btn" bindtap="addQuantity">+</view>
  </view>
  <button class="btn-outline cart-btn" bindtap="addToCart">加入购物车</button>
  <button class="btn-primary buy-btn" bindtap="buyNow">立即购买</button>
</view>