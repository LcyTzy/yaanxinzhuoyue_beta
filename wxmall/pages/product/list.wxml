<view class="page-list">
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" type="text" placeholder="搜索商品名称、编码..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="doSearch" />
    </view>
  </view>

  <view class="product-list">
    <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="product-img" src="{{item.image || '/images/product.png'}}" mode="aspectFill" binderror="onProductImageError" data-index="{{index}}" />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-code">{{item.code || ''}}</text>
        <view class="product-bottom">
          <text class="product-price">¥{{item.price}}</text>
          <text class="product-stock" wx:if="{{item.stock > 0}}">库存{{item.stock}}</text>
          <text class="product-stock out" wx:else>缺货</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{products.length === 0 && !loading}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无商品</text>
  </view>

  <view class="load-more" wx:if="{{hasMore}}">
    <text class="load-text" bindtap="loadMore">加载更多</text>
  </view>
</view>