<view class="page">
  <view class="header">
    <text class="title">采购订单</text>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待审核</view>
    <view class="tab {{activeTab === 'approved' ? 'active' : ''}}" bindtap="switchTab" data-tab="approved">已通过</view>
    <view class="tab {{activeTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
  </view>

  <view class="list">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="item-header">
        <text class="item-no">{{item.orderNo || 'PO-' + item.id}}</text>
        <text class="item-status status-{{item.status}}">{{item.statusText || '待审核'}}</text>
      </view>
      <view class="item-body">
        <text class="item-name">{{item.supplierName || '供应商'}}</text>
        <text class="item-qty">备注：{{item.remark || '无'}}</text>
      </view>
      <view class="item-footer">
        <text class="item-amount">¥{{item.totalAmount || 0}}</text>
        <view class="item-actions">
          <text class="item-time">{{item.createTime || ''}}</text>
          <text class="action-btn" wx:if="{{item.status === 'approved'}}" bindtap="confirmOrder" data-id="{{item.id}}">确认入库</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{list.length === 0 && !loading}}">
    <text class="empty-icon">📥</text>
    <text class="empty-text">暂无采购订单</text>
  </view>

  <view class="fab" bindtap="createOrder">
    <text class="fab-icon">+</text>
  </view>
</view>