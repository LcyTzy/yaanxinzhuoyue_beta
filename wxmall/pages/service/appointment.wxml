<view class="page">
  <view class="header-bar">
    <text class="header-title">服务预约</text>
    <text class="apply-btn" bindtap="showForm">立即预约</text>
  </view>

  <view class="list" wx:if="{{orders.length > 0}}">
    <view class="item" wx:for="{{orders}}" wx:key="id">
      <view class="item-row"><text class="item-label">服务类型</text><text class="item-value">{{item.serviceTypeName || '--'}}</text></view>
      <view class="item-row"><text class="item-label">车辆信息</text><text class="item-value">{{item.vehicleInfo || '--'}}</text></view>
      <view class="item-row"><text class="item-label">预约时间</text><text class="item-value">{{item.appointmentTime || '--'}}</text></view>
      <view class="item-row"><text class="item-label">状态</text><text class="item-value status">{{item.status === 'PENDING' ? '待确认' : item.status === 'CONFIRMED' ? '已确认' : item.status === 'IN_PROGRESS' ? '服务中' : item.status === 'COMPLETED' ? '已完成' : '已取消'}}</text></view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-icon">📅</text>
    <text class="empty-text">暂无预约记录</text>
  </view>

  <view class="form-mask" wx:if="{{showForm}}" bindtap="hideForm">
    <view class="form-panel" catchtap="">
      <text class="form-title">预约服务</text>
      <view class="form-item">
        <text class="label">服务类型 *</text>
        <picker mode="selector" range="{{types}}" range-key="name" bindchange="onTypeChange">
          <view class="picker">{{types.length > 0 ? types[0].name : '请选择'}}</view>
        </picker>
      </view>
      <view class="form-item"><text class="label">车辆信息</text><input class="input" value="{{form.vehicleInfo}}" data-field="vehicleInfo" bindinput="onInput" placeholder="品牌型号/车牌号" /></view>
      <view class="form-item"><text class="label">联系人 *</text><input class="input" value="{{form.contactName}}" data-field="contactName" bindinput="onInput" placeholder="请输入联系人" /></view>
      <view class="form-item"><text class="label">联系电话 *</text><input class="input" value="{{form.contactPhone}}" data-field="contactPhone" bindinput="onInput" placeholder="请输入联系电话" type="number" /></view>
      <view class="form-item"><text class="label">预约时间</text><input class="input" value="{{form.appointmentTime}}" data-field="appointmentTime" bindinput="onInput" placeholder="如：2025-01-15 14:00" /></view>
      <view class="form-item"><text class="label">备注</text><input class="input" value="{{form.remark}}" data-field="remark" bindinput="onInput" placeholder="备注信息（选填）" /></view>
      <view class="form-btns">
        <button class="cancel-btn" bindtap="hideForm">取消</button>
        <button class="submit-btn" bindtap="submit">提交预约</button>
      </view>
    </view>
  </view>
</view>