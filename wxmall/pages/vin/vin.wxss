.page-vin {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 40rpx 30rpx 36rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 8rpx;
  display: block;
}

.search-box {
  display: flex;
  margin: 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.vin-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.search-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 10rpx;
  margin-left: 16rpx;
  padding: 0;
  text-align: center;
}

.tips {
  margin: 0 20rpx 24rpx;
  background: #e6f4ff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
}

.tips-title {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.tips-text {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
}

.result-section {
  margin: 0 20rpx;
}

.vehicle-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}

.vehicle-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.vehicle-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.vehicle-info {
  flex: 1;
}

.vehicle-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
}

.vehicle-year {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.vehicle-detail {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.detail-row + .detail-row {
  border-top: 1rpx solid #eee;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
}

.detail-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.parts-section {
  margin-top: 8rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.parts-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.part-card {
  display: flex;
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}

.part-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.part-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.part-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.part-code {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.part-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.part-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #1677ff;
}

.part-stock {
  font-size: 22rpx;
  color: #52c41a;
  background: #f0fff0;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.part-stock.out {
  color: #ff4d4f;
  background: #fff0f0;
}

.empty-parts {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.empty-result {
  margin: 40rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}